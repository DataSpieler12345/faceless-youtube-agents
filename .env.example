# YT Video Factory — API Keys
# Copy this file to .env and fill in your keys

# Gathos Image API (img_live_* key)
# Get your key at https://gathos.com
GATHOS_IMAGE_API_KEY=

# Gathos TTS API (tts_live_* key — separate from image key)
# Get your key at https://gathos.com
GATHOS_TTS_API_KEY=

# Zernio API (YouTube upload)
# Get your key at https://zernio.com
# Connect your YouTube channel at zernio.com first
ZERNIO_API_KEY=

# Optional: Custom file hosting endpoint for video uploads
# Default uses file.io (free, auto-deletes after download)
# Set this to your own S3/R2/custom endpoint if needed
# FILE_HOST_URL=https://file.io
